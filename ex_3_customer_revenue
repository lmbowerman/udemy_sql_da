CREATE TABLE jan_2014_revenue AS
SELECT o.order_customer_id, 
	r.order_item_quantity,
	r.order_item_product_price,
	ROUND ((r.order_item_quantity * r.order_item_product_price)::numeric,2) as item_revenue
FROM orders as o
INNER JOIN order_items as r
	ON o.order_id = r.order_item_id
WHERE (order_status in('CLOSED', 'COMPLETE')) and (to_char(o.order_date::timestamp, 'yyyy-MM') ='2014-01')


DROP TABLE jan_2014_revenue

Select *
FROM jan_2014_revenue
	
SELECT c.customer_id, 
	c.customer_fname, 
	c.customer_lname,
	COALESCE (SUM(j.item_revenue),0) as total_customer_revenue
FROM customers as c
LEFT JOIN jan_2014_revenue as j
ON c.customer_id = j.order_customer_id
GROUP BY c.customer_id
ORDER BY total_customer_revenue DESC, c.customer_id ASC


--lecture approach
SELECT c.customer_id,
	c.customer_fname,
	c.customer_lname,
	coalesce (round(sum(oi.order_item_subtotal)::numeric, 2), 0) as customer_revenue
FROM customers as c
	LEFT OUTER JOIN orders AS o
		ON o.order_customer_id = c.customer_id
		AND  to_char(order_date, 'yyyy-MM') = '2014-01'
		AND o.order_status IN ('COMPLETE', 'CLOSED')
	LEFT OUTER JOIN order_items as oi
		ON o.order_id = oi.order_item_order_id
GROUP BY 1, 2, 3
ORDER BY 4 DESC
