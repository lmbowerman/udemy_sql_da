SELECT *,
	order_item_product_price * order_item_quantity as revenue
FROM order_items
group by order_item_id
ORDER BY revenue ASC


SELECT o.*,
	r.*
FROM orders as o
	JOIN order_items as r
	on (o.order_id = r.order_item_id)
WHERE (order_status in('CLOSED', 'COMPLETE')) and (to_char(o.order_date::timestamp, 'yyyy-MM') ='2014-01')
ORDER BY 3

SELECT c.*,
	o.*
